{
  "id": "nodebb-plugin-wkchat",
  "name": "会话列表",
  "description": "nodebb注入式会话列表，支持实时推送、未读角标、长按菜单等",
  "url": "https://bbs.886.best",
  "library": "./library.js",
  "hooks": [
    {
      "hook": "static:app.load",
      "method": "init"
    }
  ],
  "scripts": [
    "public/client.js"
  ],
  "scss": [
    "public/style.scss"
  ],
  "languages": "languages",
  "nbbpm": {
    "compatibility": "^3.0.0 || ^4.0.0"
  }
}
